# ─── AWS Credentials ──────────────────────────────────────────────────────────
# Gere em: https://console.aws.amazon.com/iam/ > Users > Security Credentials
aws_access_key = "AKIAIOSFODNN7EXAMPLE"
aws_secret_key = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# ─── SSH ──────────────────────────────────────────────────────────────────────
ssh_public_key = "ssh-rsa AAAAB3... your-key"
ssh_port       = 2277

# ─── EC2 Instance ─────────────────────────────────────────────────────────────
instance_name = "wingtradebot"
region        = "us-east-1"
instance_type = "t3.small"

# AMI Ubuntu 24.04 LTS — muda por região!
# us-east-1: ami-0a0e5d9c7acc336f1
# sa-east-1: ami-0fb4cf3a99aa89f72 (São Paulo)
ami_id = "ami-0a0e5d9c7acc336f1"

# ─── RDS PostgreSQL (Free Tier) ───────────────────────────────────────────────
# Free tier: db.t3.micro, 20 GB, 750 hrs/month for first 12 months
db_username = "wingbot"
db_password = "YourStrongDbPassword123"  # Min 8 chars, no @ or /

# Set to true during initial migration so your laptop can reach RDS
# Set to false after migration is complete
db_publicly_accessible = true

# Your local machine's public IP in CIDR notation
# Find it: curl ifconfig.me
# Example: "203.0.113.5/32"
migration_tool_ip = "YOUR_LOCAL_IP/32"
