# Generated by Ansible — edit vars/main.yml and re-run to update
# Template: infrastructure/ansible/roles/wingtradebot/templates/docker-compose.j2

services:
  # Main Node.js Trading Server
  wingtradebot:
    image: {{ docker_image_core }}:latest
    container_name: wingtradebot
    restart: always
    ports:
      - "{{ app_port | default('443') }}:443"
      - "80:80"
    environment:
      - NODE_ENV=production
      - PORT=443
      - DEBUG_LEVEL={{ debug_level | default('normal') }}
      - SERVER_IP={{ server_ip }}
      # Database
      - DB_TYPE={{ db_type | default('postgres') }}
      - DATABASE_URL={{ database_url }}
      # SimpleFX API
      - SIMPLEFX_API_KEY={{ simplefx_api_key }}
      - SIMPLEFX_API_SECRET={{ simplefx_api_secret }}
      - SIMPLEFX_API_KEY2={{ simplefx_api_key2 | default('') }}
      - SIMPLEFX_API_SECRET2={{ simplefx_api_secret2 | default('') }}
      # Account config
      - DEFAULT_ACCOUNT_NUMBER={{ default_account_number }}
      - ALL_MONITORED_ACCOUNTS={{ all_monitored_accounts }}
      - SECONDARY_API_ACCOUNTS={{ secondary_api_accounts | default('') }}
      # Dashboard auth
      - STATUS_AUTH_USERNAME={{ dashboard_username }}
      - STATUS_AUTH_PASSWORD={{ dashboard_password }}
      # IP Allowlist
      - ALLOWED_IPS={{ allowed_ips }}
      # FastAPI
      - FASTAPI_URL={{ fastapi_url | default('http://localhost:8000') }}
      # Cron
      - ORDER_SYNC_INTERVAL={{ order_sync_interval | default('30') }}
      - ENABLE_ORDER_SYNC={{ enable_order_sync | default('true') }}
    volumes:
      - ./ssl:/app/ssl:ro
      - wingtradebot_data:/app/data
    networks:
      - wingtradebot_network
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:443/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  # FastAPI Microservice
  fastapi:
    image: {{ docker_image_fastapi }}:latest
    container_name: wingtradebot-fastapi
    restart: always
    ports:
      - "8000:8000"
    environment:
      - DATABASE_URL={{ database_url }}
      - SIMPLEFX_API_KEY={{ simplefx_api_key }}
      - SIMPLEFX_API_SECRET={{ simplefx_api_secret }}
    volumes:
      - wingtradebot_data:/app/data
    networks:
      - wingtradebot_network
    depends_on:
      - wingtradebot

networks:
  wingtradebot_network:
    driver: bridge

volumes:
  wingtradebot_data:
    driver: local
