# Generated by Ansible — do not edit manually on this server
# To modify: edit vars/main.yml and re-run the playbook
# Template: infrastructure/ansible/roles/wingtradebot/templates/env.j2

# ── Server ────────────────────────────────────────────────────────────────────
PORT={{ app_port | default('443') }}
DEBUG_LEVEL={{ debug_level | default('normal') }}
SERVER_IP={{ server_ip | default('') }}
NODE_ENV=production

# ── SimpleFX API — Primary credentials ───────────────────────────────────────
SIMPLEFX_API_KEY={{ simplefx_api_key }}
SIMPLEFX_API_SECRET={{ simplefx_api_secret }}

# ── SimpleFX API — Secondary credentials (optional) ──────────────────────────
SIMPLEFX_API_KEY2={{ simplefx_api_key2 | default('') }}
SIMPLEFX_API_SECRET2={{ simplefx_api_secret2 | default('') }}

# ── Account Configuration ─────────────────────────────────────────────────────
DEFAULT_ACCOUNT_NUMBER={{ default_account_number | default('') }}
# Comma-separated list of all accounts to monitor
ALL_MONITORED_ACCOUNTS={{ all_monitored_accounts | default(default_account_number) | default('') }}
# Comma-separated list of accounts using secondary API (leave empty if none)
SECONDARY_API_ACCOUNTS={{ secondary_api_accounts | default('') }}

# ── IP Allowlist (TradingView IPs + your server IP) ───────────────────────────
# Comma-separated. TradingView IPs are pre-filled; add your server IP.
ALLOWED_IPS={{ allowed_ips | default('52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7,127.0.0.1,::1') }}

# ── Dashboard Authentication ──────────────────────────────────────────────────
STATUS_AUTH_USERNAME={{ dashboard_username | default('admin') }}
STATUS_AUTH_PASSWORD={{ dashboard_password }}
STATUS_AUTH2_USERNAME={{ dashboard_username | default('admin') }}
STATUS_AUTH2_PASSWORD={{ dashboard_password }}

# ── Database ──────────────────────────────────────────────────────────────────
# DB_TYPE: 'sqlite' for local/legacy, 'postgres' for cloud deployments
DB_TYPE={{ db_type | default('sqlite') }}
# DATABASE_URL: required when DB_TYPE=postgres
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL={{ database_url | default('') }}
# DB_FILE: SQLite file path (only used when DB_TYPE=sqlite)
DB_FILE={{ db_file | default('./sfx_historical_orders.db') }}

# ── Inter-service Communication ───────────────────────────────────────────────
# URL of the FastAPI microservice (if running alongside Node.js)
FASTAPI_URL={{ fastapi_url | default('http://localhost:8000') }}

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
ORDER_SYNC_INTERVAL={{ order_sync_interval | default('30') }}
ENABLE_ORDER_SYNC={{ enable_order_sync | default('true') }}
