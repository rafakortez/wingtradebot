# WingTradeBot — Environment Variables Template
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in your real values in .env
#   NEVER commit .env — it is already in .gitignore
#
# All values here are read by:
#   - Node.js (src/config.example.ts → src/config.ts)
#   - Python FastAPI / Flask (shared/config.py)
#   - Django (apps/django_app/wingtradebot/settings.py)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=443
DEBUG_LEVEL=normal
SERVER_IP=your_server_public_ip
NODE_ENV=production

# ── SimpleFX API — Primary credentials ───────────────────────────────────────
SIMPLEFX_API_KEY=your_primary_api_key
SIMPLEFX_API_SECRET=your_primary_api_secret

# ── SimpleFX API — Secondary credentials (optional) ──────────────────────────
# Leave empty if you only have one set of credentials
SIMPLEFX_API_KEY2=
SIMPLEFX_API_SECRET2=

# ── Account Configuration ─────────────────────────────────────────────────────
DEFAULT_ACCOUNT_NUMBER=your_account_number
# Comma-separated list of all accounts to monitor
ALL_MONITORED_ACCOUNTS=your_account_number
# Comma-separated list of accounts using secondary API (leave empty if none)
SECONDARY_API_ACCOUNTS=

# ── IP Allowlist ──────────────────────────────────────────────────────────────
# Comma-separated. TradingView IPs are pre-filled.
# Add your server IP and any other trusted IPs.
ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7,your_server_ip,127.0.0.1,::1

# ── Dashboard Authentication ──────────────────────────────────────────────────
STATUS_AUTH_USERNAME=admin
STATUS_AUTH_PASSWORD=your_strong_password_here
STATUS_AUTH2_USERNAME=admin
STATUS_AUTH2_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────────
# DB_TYPE: 'sqlite' for local development, 'postgres' for cloud deployments
DB_TYPE=sqlite
# DATABASE_URL: required when DB_TYPE=postgres
# Get this from: terraform output db_endpoint (after running terraform apply)
# Format: postgres://USERNAME:PASSWORD@HOSTNAME:5432/wingtradebot
DATABASE_URL=
# DB_FILE: SQLite file path (only used when DB_TYPE=sqlite)
DB_FILE=./sfx_historical_orders.db

# ── Inter-service Communication ───────────────────────────────────────────────
# URL of the FastAPI microservice
# Local dev: http://localhost:8000
# Docker Compose: http://fastapi_proxy:8000
FASTAPI_URL=http://localhost:8000

# ── Framework-specific Ports ──────────────────────────────────────────────────
FASTAPI_PORT=8000
FLASK_PORT=5000
DJANGO_PORT=8001

# ── Framework-specific Secrets ───────────────────────────────────────────────
FLASK_SECRET_KEY=your_flask_secret_key_here
DJANGO_SECRET_KEY=your_django_secret_key_here

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
ORDER_SYNC_INTERVAL=30
ENABLE_ORDER_SYNC=true

# ── Bybit (optional — leave empty if not used) ────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true
